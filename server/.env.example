# ============================================================
# SERVER — Render environment variables
# ============================================================
# Render injects PORT automatically — do NOT add PORT manually.
# Set all other vars in Render dashboard → Environment.
# Required vars will cause the server to exit on startup if missing.

# ── Core ────────────────────────────────────────────────────
NODE_ENV=production
# PORT=3000  # Render sets this automatically

# ── Database (REQUIRED) ─────────────────────────────────────
DATABASE_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/nicori?retryWrites=true&w=majority

# ── Auth (REQUIRED) ─────────────────────────────────────────
# Generate secrets: openssl rand -base64 32
JWT_SECRET=
SESSION_SECRET=
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# ── Server URL (REQUIRED — one must be set) ─────────────────
# Render sets RENDER_EXTERNAL_URL automatically.
# If using a different host, set SERVER_URL instead.
# RENDER_EXTERNAL_URL=
SERVER_URL=

# ── CORS ────────────────────────────────────────────────────
# Vercel frontend URL (no trailing slash)
CLIENT_URL=

# ── Redis (optional) ────────────────────────────────────────
# Recommended for multi-instance Render deploys
REDIS_URL=

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info

# ── SMTP — password reset emails (optional) ─────────────────
# Leave all empty to skip email sending
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Google OAuth (optional) ─────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitHub OAuth (optional) ─────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
