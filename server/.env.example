# ============================================================
# SERVER — Render environment variables
# ============================================================
# Render injects PORT automatically — do not override it.
# Set all other vars in Render dashboard → Environment.

NODE_ENV=production

# Render sets this automatically — do NOT add PORT manually on Render
# PORT=3000

# MongoDB Atlas connection string
# Get it from Atlas → Connect → Drivers
DATABASE_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/nicori?retryWrites=true&w=majority

# Redis (optional — leave empty to use in-memory Socket.io adapter)
# Recommended for multi-instance Render deploys
REDIS_URL=

# Secrets — generate with: openssl rand -base64 32
JWT_SECRET=
SESSION_SECRET=

# Vercel frontend URL — used for CORS allowlist (no trailing slash)
# Example: https://nicori.vercel.app
CLIENT_URL=

# User ID of the site creator — only this user can assign the "creator" badge
# Copy the _id field from the user document in MongoDB
CREATOR_USER_ID=

# SMTP (for forgot-password emails)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
