{
  "name": "aetherpulse-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development node ./build.mjs && node --enable-source-maps --env-file=../.env ./dist/server.mjs",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps --env-file=../.env ./dist/server.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts",
    "seed": "node ./scripts/seed.mjs"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.19.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.11.0",
    "jsonwebtoken": "^9.0.2",
    "media-typer": "^2.0.0",
    "mongoose": "^8.7.0",
    "nanoid": "^5.1.11",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "sharp": "^0.35.2",
    "socket.io": "^4.8.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/mongoose": "^5.11.97",
    "@types/node": "^25.9.1",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vue/eslint-config-standard": "^8.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "cross-env": "^10.1.0",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^8.10.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-vue": "^9.0.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^6.3.3",
    "thread-stream": "3.1.0",
    "typescript": "~6.0.3",
    "vitest": "^3.2.6",
    "vue-eslint-parser": "^9.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
