{
  "name": "aetherpulse-monorepo",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "node -e \"require('fs').copyFileSync('.env', 'shared/db/.env')\" && pnpm --filter @workspace/db push && turbo dev",
    "db:push": "pnpm --filter @workspace/db push",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "start:client": "pnpm --filter aetherpulse-client dev",
    "start:server": "pnpm --filter aetherpulse-server dev",
    "build:client": "pnpm --filter aetherpulse-client build",
    "build:server": "pnpm --filter aetherpulse-server build"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "turbo": "^2.1.2",
    "typescript": "~5.9.3"
  },
  "packageManager": "pnpm@10.4.1",
  "dependencies": {
    "events": "^3.3.0",
    "util": "^0.12.5",
    "util-browser": "^0.0.2"
  }
}
