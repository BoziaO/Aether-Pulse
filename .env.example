# ============================================================================
# AetherPulse Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the values for development
# For production, use proper secrets management (Docker secrets, Kubernetes, etc.)

# ============================================================================
# Node Environment
# ============================================================================
NODE_ENV=development

# ============================================================================
# Server Configuration
# ============================================================================
PORT=3000
SERVER_PORT=3000
HOST=0.0.0.0

# ============================================================================
# Database Configuration
# ============================================================================
# MongoDB connection URL
DATABASE_URL=mongodb://localhost:27017/aetherpulse

# Redis connection URL (for caching and sessions)
REDIS_URL=redis://localhost:6379

# ============================================================================
# Security Secrets
# ============================================================================
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_at_least_32_chars_long

# Generate with: openssl rand -base64 32
SESSION_SECRET=your_session_secret_at_least_32_chars_long

# ============================================================================
# Client Configuration
# ============================================================================
CLIENT_URL=http://localhost:5174
CLIENT_PORT=5174

# ============================================================================
# API Configuration
# ============================================================================
API_BASE_PATH=/api

# ============================================================================
# File Upload Configuration
# ============================================================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=info

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# CORS Configuration
# ============================================================================
CORS_ORIGIN=http://localhost:5173,http://localhost:80,http://localhost:3000

# ============================================================================
# Socket.IO Configuration
# ============================================================================
SOCKET_IO_CORS_ORIGIN=http://localhost:5174
SOCKET_IO_PATH=/api/socket.io
