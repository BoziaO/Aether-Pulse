# ==============================================================================
# AetherPulse Root Environment Variables
# ==============================================================================

# Database Configuration (MongoDB)
# Local: mongodb://localhost:27017/aetherpulse
# Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
DATABASE_URL=mongodb://localhost:27017/aetherpulse

# Server Configuration
PORT=3000
NODE_ENV=development
SESSION_SECRET=your_very_secret_session_key_here
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# Client Configuration
# The port the client dev server should run on
CLIENT_PORT=5173
CLIENT_URL=http://localhost:5173
# The base path for the application (default is /)
BASE_PATH=/

# External API Keys (if applicable)
# STUN_SERVER_URL=
# TURN_SERVER_URL=
# TURN_SERVER_USERNAME=
# TURN_SERVER_PASSWORD=
