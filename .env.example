# ============================================================
# LOCAL DEVELOPMENT — copy to .env and fill in values
# ============================================================

NODE_ENV=development
PORT=3000

# MongoDB Atlas or local Mongo
DATABASE_URL=mongodb://localhost:27017/aetherpulse

# Redis (optional — leave empty to use in-memory Socket.io adapter)
REDIS_URL=

# Secrets — generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_at_least_32_chars_long
SESSION_SECRET=your_session_secret_at_least_32_chars_long

# CORS — allowed client origin
CLIENT_URL=http://localhost:5174
