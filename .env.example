# ============================================================
# LOCAL DEVELOPMENT — copy to .env and fill in values
# ============================================================
# Required vars will cause the server to exit on startup if missing.
# Generate secrets: openssl rand -base64 32

# ── Core ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database (REQUIRED) ─────────────────────────────────────
# MongoDB Atlas: mongodb+srv://<user>:<pass>@<cluster>/nicori
# Local:        mongodb://localhost:27017/nicori
DATABASE_URL=mongodb://localhost:27017/nicori

# ── Auth (REQUIRED) ─────────────────────────────────────────
JWT_SECRET=your_jwt_secret_at_least_16_chars
SESSION_SECRET=your_session_secret_at_least_32_chars
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# ── Server URL (one REQUIRED in production) ─────────────────
# Auto-injected by Render. For local dev, default is http://localhost:3000
SERVER_URL=http://localhost:3000
# RENDER_EXTERNAL_URL=

# ── CORS ────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5174

# ── Redis (optional) ────────────────────────────────────────
# Leave empty to use in-memory Socket.io adapter (fine for single instance).
# Required for multi-instance / horizontal scaling.
REDIS_URL=

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info

# ── SMTP — password reset emails (optional) ─────────────────
# Leave all empty to skip email sending (resets will use token-in-URL fallback).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Google OAuth (optional) ─────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitHub OAuth (optional) ─────────────────────────────────
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
