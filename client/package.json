{
  "name": "aetherpulse-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "description": "AetherPulse desktop client (Electron wrapper for the Vue web app).",
  "author": {
    "name": "Maciej Łada",
    "email": "contact@aetherpulse.app",
    "url": "https://github.com/BoziaO"
  },
  "scripts": {
    "dev": "vite --config vite.config.ts --host 0.0.0.0 --port 5174",
    "build": "vite build --config vite.config.ts",
    "serve": "vite preview --config vite.config.ts --host 0.0.0.0 --port 5174",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --ext .vue,.ts,.tsx,.js,.jsx,.cjs,.mjs",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --watch",
    "electron:dev": "concurrently --kill-others \"pnpm dev\" \"pnpm --filter aetherpulse-server dev\" \"wait-on http://localhost:5174 && wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "electron:dev:build": "pnpm build && cross-env NODE_ENV=development electron .",
    "electron:build": "cross-env LOCAL_WRAPPER=true pnpm build && electron-builder --win",
    "electron:build:linux": "cross-env LOCAL_WRAPPER=true pnpm build && electron-builder --linux",
    "electron:build:mac": "cross-env LOCAL_WRAPPER=true pnpm build && electron-builder --mac",
    "android:sync": "cross-env LOCAL_WRAPPER=true pnpm build && npx cap sync",
    "android:open": "npx cap open android",
    "android:build": "cross-env LOCAL_WRAPPER=true pnpm build && npx cap sync android && npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@vueuse/core": "^13.9.0",
    "lucide-vue-next": "^0.479.0",
    "pinia": "^3.0.4",
    "process": "^0.11.10",
    "simple-peer": "^9.11.1",
    "socket.io-client": "^4.8.3",
    "util": "^0.12.5",
    "util-browser": "^0.0.2",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0",
    "vue-virtual-scroller": "^3.0.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@replit/vite-plugin-cartographer": "^0.5.1",
    "@replit/vite-plugin-dev-banner": "^0.1.2",
    "@replit/vite-plugin-runtime-error-modal": "^0.0.6",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^25.9.1",
    "@types/simple-peer": "^9.11.9",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-standard": "^8.0.0",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^8.10.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-vue": "^9.0.0",
    "jsdom": "^25.0.1",
    "lightningcss": "^1.32.0",
    "tailwindcss": "^4.3.0",
    "tslib": "^2.8.1",
    "typescript": "~6.0.3",
    "vite": "^6.4.2",
    "vitest": "^3.2.6",
    "vue-eslint-parser": "^9.0.0",
    "vue-tsc": "^3.3.3",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.aetherpulse.app",
    "productName": "AetherPulse",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icons/logo.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icons/logo.png"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        },
        {
          "target": "zip",
          "arch": ["x64"]
        }
      ],
      "icon": "public/icons/logo.png",
      "category": "Network"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "engines": {
    "node": ">=22.0.0"
  }
}