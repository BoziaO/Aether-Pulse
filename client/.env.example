# ============================================================
# CLIENT — Vercel environment variables
# ============================================================
# Copy to .env.local for local dev, set in Vercel dashboard for production.
# All VITE_* vars are inlined at build time — never put secrets here.

# Full URL of the Render Express server (no trailing slash)
# Dev:        leave empty — Vite proxy forwards /api/* to localhost:3000
# Production: https://your-app.onrender.com
VITE_API_URL=
