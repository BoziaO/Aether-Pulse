# GitIgnore for Nicori
# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# ============================================================================
# Build Output
# ============================================================================
dist
dist-*
build/
tmp/
out-tsc/
*.tsbuildinfo
.tsbuildinfo

# Electron
dist-electron/
*.exe
*.dmg
*.AppImage
*.deb
*.rpm
*.zip
*.tar
*.tar.gz

# Expo
.expo/
.expo-shared/

# ============================================================================
# Dependencies
# ============================================================================
node_modules/
.pnpm-store/

# ============================================================================
# IDE Configuration
# ============================================================================
# WebStorm
.idea/
*.iml
*.iws
*.ipr

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/keybindings.json

# General IDE
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.sublime-project
*.swp
*.swo
*~
.netvsrc
.njsproj
.sln
.suo

# ============================================================================
# Logs and Debug
# ============================================================================
.sass-cache/
connect.lock
libpeerconnection.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
testem.log
/typings

# Coverage
coverage/
.nyc_output/

# ============================================================================
# System Files
# ============================================================================
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# macOS
.ds_store
.appledouble
.lsoverride

# Linux
*~nfs*

# ============================================================================
# Platform Specific
# ============================================================================
# Cursor/Next.js
.cursor/
.github/instructions/

# Replit
.cache/
.local/

# ============================================================================
# Environment and Configuration
# ============================================================================
.env
.env.*
!.env.example
*.local

# ============================================================================
# Turborepo
# ============================================================================
.turbo/

# ============================================================================
# Logs
# ============================================================================
logs/
*.log
logs/*.*

# ============================================================================
# Databases
# ============================================================================
*.db
*.db-journal
*.db-shm
*.db-wal
*.sqlite
*.sqlite-journal

# ============================================================================
# Uploads and Temporary Files
