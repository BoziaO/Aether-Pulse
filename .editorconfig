# EditorConfig helps maintain consistent coding styles across editors
# https://editorconfig.org

root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

# Markdown files - preserve trailing whitespace for tables
[*.md]
trim_trailing_whitespace = false

# JSON files
[*.json]
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_size = 2

# TypeScript and JavaScript files
[*.{ts,tsx,js,jsx,vue,cjs,mjs}]
indent_size = 2

# Package files - allow longer lines
[{package.json,package-lock.json,pnpm-lock.yaml,tsconfig.json}]
max_line_length = 200

# Makefile requires tabs
[Makefile]
indent_style = tab

# Shell scripts
[*.sh]
indent_size = 2
end_of_line = lf

# Docker files
[Dockerfile]
indent_size = 2
end_of_line = lf

# Configuration files
[*.{toml,ini,cfg,conf}]
end_of_line = lf

# Binary files
[*.{png,jpg,jpeg,gif,svg,ico,woff,woff2,ttf,eot}]
binary = true
