# pnpm configuration
# Using pnpm as package manager (defined in package.json)

# Peer dependencies handling
auto-install-peers=false
strict-peer-dependencies=false

# Security: respect minimum release age from pnpm-workspace.yaml
# This is managed by pnpm workspace settings, not npmrc
# minimum-age is not applicable for pnpm

# Node version manager
engine-strict=true

# Save exact versions
save-exact=true

# Ignore scripts for security
ignore-scripts=false

# Shamefully hoist for monorepo
shamefully-hoist=true
